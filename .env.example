# ---- Database (Prisma / Neon Postgres) ----
# Pooled URL (pgbouncer) for the app at runtime. connect_timeout/pool_timeout cover Neon's
# free-tier cold start (the DB auto-suspends when idle and takes a few seconds to wake).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=20&pool_timeout=20"
# Direct (non-pooled) URL for migrations / prisma db push:
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=20"

# ---- Auth.js (NextAuth) ----
# Generate with: npx auth secret   (or any 32+ char random string)
AUTH_SECRET="dev-only-change-me-please-32chars-min"
# Base URL of the app
NEXTAUTH_URL="http://localhost:3000"

# ---- Storage ----
# STORAGE_DRIVER: "local" (dev, writes to ./storage) or "r2" (prod, any S3-compatible store)
STORAGE_DRIVER="local"
# Any S3-compatible provider (Backblaze B2 recommended, or Cloudflare R2 / Supabase / MinIO).
# Set S3_ENDPOINT to the provider's endpoint; for Backblaze B2 also set S3_REGION.
#   Backblaze B2:  S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com  S3_REGION=us-east-005
#   Cloudflare R2: S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT=""
S3_REGION="auto"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="cad-models"
R2_PUBLIC_BASE_URL=""

# ---- Email ----
# Not used. Sharing grants access by email and the invitee sees the model under
# "Shared with you" after signing in. Send them the project link directly.
